# Default: Solana Foundation public RPC (no signup, rate-limited).
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Alchemy free tier (~30M CU/month, ~30 req/s): make alchemy-dashboard → Apps → Solana Mainnet → API Key
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/PASTE_YOUR_ALCHEMY_API_KEY_HERE
SOLANA_CLUSTER=mainnet-beta

# Optional default pool for npm run fetch:pool (can also pass --pool <ADDRESS>)
# METEORA_POOL_ADDRESS=5rCf1DM8LjKTw4YqhnoLcngyZYeNnQqztScTogYHAS6

# Faster snapshot polling once on a private RPC (defaults are conservative for public RPC):
# make poll-snapshots SERIES_RPC_BACKOFF_SEC=5 SERIES_INTERVAL_SEC=10
